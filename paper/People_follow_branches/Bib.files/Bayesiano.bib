	keywords = {Asymmetric Laplace distribution, Bayesian inference, Markov chain Monte Carlo methods, Quantile regression},
	pages = {437--447},
	file = {Yu e Moyeed - 2001 - Bayesian quantile regression.pdf:C\:\\Users\\loren\\Zotero\\storage\\FNP39QY4\\Yu e Moyeed - 2001 - Bayesian quantile regression.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\loren\\Zotero\\storage\\L7R7LGWW\\S0167715201001249.html:text/html},
